{
  "functions": {
    "api/generate.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/gizlilik.html",
      "dest": "/public/gizlilik.html"
    },
    {
      "src": "/kullanim.html",
      "dest": "/public/kullanim.html"
    },
    {
      "src": "/iletisim.html",
      "dest": "/public/iletisim.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
