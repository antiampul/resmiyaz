{
  "version": 2,
  "functions": {
    "api/generate.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/generate.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
